# Copy this file to member1-acc.env and fill in your values
# === Base identifiers (required) ===
AWS_ACCOUNT_ID="123456789012"
AWS_PROFILE="member1-acc"
AWS_REGION="us-east-1"
PROJECT_NAME="frontier-agent-hub"

# === GitHub ===
GITHUB_ORG="my-org"
GITHUB_REPO="my-repo"
GITHUB_INTEGRATION_ID=""

# === Domain ===
DOMAIN="my-domain.com"

# === DevOps Agent Data Sources (optional) ===
# GitHub: GITHUB_ORG, GITHUB_REPO, GITHUB_INTEGRATION_ID above are auto-mapped to Agent Association.
# Set GITHUB_OWNER_TYPE if the owner is an organization.
GITHUB_OWNER_TYPE="user"     # "organization" or "user"

# Slack association — enables DevOps Agent to post incident alerts
SLACK_WORKSPACE_ID=""        # e.g. "T0XXXXXXX"
SLACK_WORKSPACE_NAME=""      # e.g. "my-team"
SLACK_AGENT_CHANNEL_ID=""    # e.g. "C0XXXXXXX"
SLACK_AGENT_CHANNEL_NAME=""  # e.g. "#devops-alerts"

# === Derived (leave blank to auto-compute from base values) ===
ECR_REGISTRY=""
EKS_CLUSTER_NAME=""
