  "forbidden_rules": [
    {
      "description": "In-cluster databases/caches must use K8s icons, not cloud-managed icons",
      "condition": "category == 'k8s_workload' AND provider_type starts with 'k8s.'",
      "bad_style_fragment": "mxgraph.aws4.elasticache",
      "correct_template": "k8s_deployment"
    },
    {
      "description": "K8s workloads must not use plain rectangles on L2/L3",
      "condition": "category == 'k8s_workload' AND level in ('L2', 'L3')",
      "bad_style_fragment": "rounded=1;whiteSpace=wrap",
      "exception": "l3_detail.type == 'detail_card' (card itself is allowed, but must be paired with icon)",
      "correct_template": "k8s_deployment or k8s_service"
    }
  ]
}
