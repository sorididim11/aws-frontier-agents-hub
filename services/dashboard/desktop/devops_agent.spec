    hookspath=[],
    runtime_hooks=[os.path.join(SPECPATH, "runtime_hook.py")],
    excludes=["gunicorn", "tkinter", "pytest"],
    noarchive=False,
    cipher=block_cipher,
)

pyz = PYZ(a.pure, a.zipped_data, cipher=block_cipher)

exe = EXE(
    pyz,
    a.scripts,
    [],
    exclude_binaries=True,
    name="DevOpsAgent",
    debug=False,
    strip=False,
    upx=False,
    console=False,
)

coll = COLLECT(
    exe,
    a.binaries,
    a.zipfiles,
    a.datas,
    strip=False,
    upx=False,
    name="DevOpsAgent",
)

app = BUNDLE(
    coll,
    name="DevOps Agent.app",
    bundle_identifier="com.devops-agent.dashboard",
    info_plist={
        "CFBundleShortVersionString": "1.0.0",
        "CFBundleVersion": "1",
        "NSHighResolutionCapable": True,
        "LSMinimumSystemVersion": "12.0",
    },
)
