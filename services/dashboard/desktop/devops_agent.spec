"""PyInstaller spec for DevOps Agent Dashboard (macOS)."""
import os

block_cipher = None

DASHBOARD_DIR = os.path.abspath(os.path.join(SPECPATH, ".."))
REPO_ROOT = os.path.abspath(os.path.join(DASHBOARD_DIR, "..", ".."))

a = Analysis(
    [os.path.join(SPECPATH, "launcher.py")],
    pathex=[DASHBOARD_DIR, REPO_ROOT],
    binaries=[],
    datas=[
        (os.path.join(SPECPATH, "flask_server.py"), "desktop"),
        (os.path.join(DASHBOARD_DIR, "templates"), "templates"),
        (os.path.join(DASHBOARD_DIR, "static"), "static"),
        (os.path.join(DASHBOARD_DIR, "config.yaml.example"), "."),
        (os.path.join(DASHBOARD_DIR, "arch_questions.json"), "."),
        (os.path.join(DASHBOARD_DIR, "prompts"), "prompts"),
        (os.path.join(DASHBOARD_DIR, "generation"), "generation"),
        (os.path.join(DASHBOARD_DIR, "providers"), "providers"),
        (os.path.join(DASHBOARD_DIR, "scenarios"), "scenarios"),
        (os.path.join(DASHBOARD_DIR, "dockercoins-scenarios"), "dockercoins-scenarios"),
        (os.path.join(REPO_ROOT, "simulator", "engine"), "simulator/engine"),
        (os.path.join(DASHBOARD_DIR, "expert_sidecar", "dist"), "expert_sidecar/dist"),
        (os.path.join(DASHBOARD_DIR, "expert_sidecar", "node_modules_prod"), "expert_sidecar/node_modules"),
        (os.path.join(DASHBOARD_DIR, "expert_sidecar", "package.json"), "expert_sidecar"),
        (os.path.join(SPECPATH, "node"), "node"),
    ],
    hiddenimports=[
        "flask",
        "flask_compress",
        "jinja2",
        "jinja2.ext",
