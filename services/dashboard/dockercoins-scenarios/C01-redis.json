{
  "id": "C01-redis",
  "name": "Redis Pod Failure",
  "category": "multi-service",
  "layer": "Composite → Cache/Queue",
  "purpose": "캐시/큐 서버 장애가 전체 시스템에 미치는 영향 분석",
  "flow": [
    "Redis Pod 강제 삭제",
    "Worker에서 Redis 연결 실패",
    "Redis Pod 자동 재시작",
    "시스템 자동 복구"
  ],
  "expected_root_cause": "Root Cause: redis Pod 장애 (NOT worker 코드 버그)",
  "trigger": {
    "type": "kubectl",
    "command": "kubectl delete pod -n dockercoins -l app=redis --force --grace-period=0"
  },
  "restore": {
    "command": ""
  },
  "verification": {
    "steps": [
      {
        "name": "Worker 연결 에러 확인",
        "type": "pod_logs",
        "pod": "worker",
        "pattern": "ConnectionError|redis",
        "timeout": 30,
        "poll_interval": 5
      },
      {
        "name": "Redis 복구 확인",
        "type": "manual",
        "description": "Redis 복구 확인: kubectl get pods -n dockercoins -l app=redis",
        "timeout": 60
      }
    ]
  },
  "evaluation_rubric": {
    "root_cause_match": {
      "weight": 30,
      "criteria": "근본 원인이 Redis 연결 실패임을 정확히 식별했는가"
    },
    "data_sources": {
      "weight": 25,
      "required": [
        "K8s",
        "CloudWatch",
        "Logs"
      ],
      "criteria": "K8s pod 상태, CloudWatch 알람, Redis 연결 로그를 활용했는가"
    },
    "causal_chain": {
      "weight": 20,
      "criteria": "Redis 장애 → worker 연결 실패 → 서비스 중단 인과관계를 설명했는가"
    },
    "false_leads": {
      "weight": 15,
      "criteria": "잘못된 방향에 시간을 낭비하지 않았는가"
    },
    "code_analysis": {
      "weight": 10,
      "criteria": "Redis 연결 코드를 분석했는가"
    }
  }
}